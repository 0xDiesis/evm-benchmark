# Pumba Network Chaos Profiles
#
# Source one of these profile blocks before starting the compose stack,
# or pass them directly as env vars.
#
# Values are in milliseconds for delay/jitter.
#
# Usage:
#   source docker/pumba/profiles.env && apply_profile global
#   docker compose -f docker/docker-compose.e2e.yml -f docker/docker-compose.pumba.yml up -d

# --- Profile: continental ---
# Validators spread across one continent (e.g., US East, US West, US Central, Canada)
# Realistic for a regional validator set.
continental_NODE1_DELAY=5
continental_NODE1_JITTER=2
continental_NODE2_DELAY=20
continental_NODE2_JITTER=5
continental_NODE3_DELAY=40
continental_NODE3_JITTER=8
continental_NODE4_DELAY=60
continental_NODE4_JITTER=12
continental_NODE4_LOSS=0

# --- Profile: global ---
# Validators spread worldwide (US-East, US-West, EU-West, Asia-Pacific)
# Realistic for a globally distributed validator set.
global_NODE1_DELAY=5
global_NODE1_JITTER=2
global_NODE2_DELAY=30
global_NODE2_JITTER=8
global_NODE3_DELAY=80
global_NODE3_JITTER=15
global_NODE4_DELAY=200
global_NODE4_JITTER=40
global_NODE4_LOSS=1

# --- Profile: clustered ---
# Most validators co-located in one datacenter region, one outlier far away.
# Tests how the protocol handles one slow validator.
clustered_NODE1_DELAY=1
clustered_NODE1_JITTER=1
clustered_NODE2_DELAY=2
clustered_NODE2_JITTER=1
clustered_NODE3_DELAY=3
clustered_NODE3_JITTER=1
clustered_NODE4_DELAY=120
clustered_NODE4_JITTER=25
clustered_NODE4_LOSS=2

# --- Profile: degraded ---
# All links have moderate latency with high jitter — simulates congested network.
degraded_NODE1_DELAY=30
degraded_NODE1_JITTER=20
degraded_NODE2_DELAY=40
degraded_NODE2_JITTER=25
degraded_NODE3_DELAY=50
degraded_NODE3_JITTER=30
degraded_NODE4_DELAY=80
degraded_NODE4_JITTER=40
degraded_NODE4_LOSS=3

# Helper function: apply_profile <profile_name>
# Exports PUMBA_NODE*_DELAY/JITTER/LOSS vars from the named profile.
apply_profile() {
    local profile="${1:?Usage: apply_profile <continental|global|clustered|degraded>}"
    export PUMBA_NODE1_DELAY=$(eval echo \$${profile}_NODE1_DELAY)
    export PUMBA_NODE1_JITTER=$(eval echo \$${profile}_NODE1_JITTER)
    export PUMBA_NODE2_DELAY=$(eval echo \$${profile}_NODE2_DELAY)
    export PUMBA_NODE2_JITTER=$(eval echo \$${profile}_NODE2_JITTER)
    export PUMBA_NODE3_DELAY=$(eval echo \$${profile}_NODE3_DELAY)
    export PUMBA_NODE3_JITTER=$(eval echo \$${profile}_NODE3_JITTER)
    export PUMBA_NODE4_DELAY=$(eval echo \$${profile}_NODE4_DELAY)
    export PUMBA_NODE4_JITTER=$(eval echo \$${profile}_NODE4_JITTER)
    export PUMBA_NODE4_LOSS=$(eval echo \$${profile}_NODE4_LOSS)
    echo "Applied Pumba profile: ${profile}"
    echo "  node-1: ${PUMBA_NODE1_DELAY}ms ± ${PUMBA_NODE1_JITTER}ms"
    echo "  node-2: ${PUMBA_NODE2_DELAY}ms ± ${PUMBA_NODE2_JITTER}ms"
    echo "  node-3: ${PUMBA_NODE3_DELAY}ms ± ${PUMBA_NODE3_JITTER}ms"
    echo "  node-4: ${PUMBA_NODE4_DELAY}ms ± ${PUMBA_NODE4_JITTER}ms (loss: ${PUMBA_NODE4_LOSS}%)"
}
